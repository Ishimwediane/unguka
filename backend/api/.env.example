# =============================================================
# Unguka — Backend API Environment Variables Template
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================

# ─── Application ─────────────────────────────────────────────
PORT=3000

# ─── Database (MongoDB Atlas) ────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/unguka?retryWrites=true&w=majority&appName=unguka

# ─── Authentication ──────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
